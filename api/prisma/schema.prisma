generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  DEFAULT
  REFERRAL_PARTNER
  SELLER
  ADMIN
}

enum Currency {
  RUB
}

enum OrderStatus {
  CREATED
  AWAITING_PAYMENT
  PAID
  SHIPPED
  DELIVERED
  CASHBACK_ACCRUED
  CANCELLED
}

enum CatalogCollectionType {
  CATEGORY
  PRODUCT
}

enum AdStatus {
  DRAFT
  PENDING_MODERATION
  PUBLISHED
  REJECTED
  ARCHIVED
}

model User {
  id        String    @id @default(uuid())
  email     String
  firstName String
  lastName  String
  role      UserRole  @default(DEFAULT)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  passwordHash String?

  patronymic   String?
  phone        String?
  referralCode String?

  avatarId String?
  avatar   Image?  @relation("UserAvatar", fields: [avatarId], references: [id])

  cartItems  CartItem[]
  orders     Order[]
  ads        Ad[]
  favourites Favourite[]

  invitedReferrals Referral[] @relation("Inviter")
  receivedReferral Referral?  @relation("Invited")
  balance          Balance?
}

model Favourite {
  id        String   @id @default(uuid())
  userId    String
  productId String?
  adId      String?
  createdAt DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: Cascade)
  ad      Ad?      @relation(fields: [adId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@unique([userId, adId])
}

model Balance {
  id       String   @id @default(uuid())
  userId   String   @unique
  value    Int
  currency Currency @default(RUB)

  user User @relation(fields: [userId], references: [id])
}

model Image {
  id        String  @id @default(uuid())
  url       String
  sortOrder Int
  alt       String?

  userAvatars  User[]           @relation("UserAvatar")
  categories   MarketCategory[]
  adCategories AdCategory[]
  products     ProductImage[]
  ads          AdImage[]
}

model MarketCategory {
  id        String @id @default(uuid())
  name      String
  slug      String
  sortOrder Int

  description String?
  parentId    String?
  imageId     String?

  isActive  Boolean   @default(true)
  deletedAt DateTime?

  parent   MarketCategory?  @relation("MarketCategoryTree", fields: [parentId], references: [id])
  children MarketCategory[] @relation("MarketCategoryTree")

  image    Image?    @relation(fields: [imageId], references: [id])
  products Product[]

  collectionCategories CatalogCollectionCategory[]

  @@map("Category")
}

model Product {
  id          String @id @default(uuid())
  categoryId  String
  title       String
  slug        String
  description String
  price       Int

  isActive  Boolean   @default(true)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  category MarketCategory @relation(fields: [categoryId], references: [id])
  images   ProductImage[]

  cartItems  CartItem[]
  orderItems OrderItem[]
  favourites Favourite[]

  collectionProducts CatalogCollectionProduct[]
}

model AdCategory {
  id        String @id @default(uuid())
  name      String
  slug      String
  sortOrder Int

  description String?
  parentId    String?
  imageId     String?

  isActive  Boolean   @default(true)
  deletedAt DateTime?

  parent   AdCategory?  @relation("AdCategoryTree", fields: [parentId], references: [id])
  children AdCategory[] @relation("AdCategoryTree")

  image Image? @relation(fields: [imageId], references: [id])
  ads   Ad[]
}

model Ad {
  id          String   @id @default(uuid())
  categoryId  String
  sellerId    String
  title       String
  slug        String
  description String
  price       Int
  status      AdStatus @default(PENDING_MODERATION)

  isActive    Boolean   @default(true)
  deletedAt   DateTime?
  moderatedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  category   AdCategory  @relation(fields: [categoryId], references: [id])
  seller     User        @relation(fields: [sellerId], references: [id])
  images     AdImage[]
  favourites Favourite[]
  cartItems  CartItem[]
}

model AdImage {
  adId    String
  imageId String

  ad    Ad    @relation(fields: [adId], references: [id])
  image Image @relation(fields: [imageId], references: [id])

  @@id([adId, imageId])
}

model ProductImage {
  productId String
  imageId   String

  product Product @relation(fields: [productId], references: [id])
  image   Image   @relation(fields: [imageId], references: [id])

  @@id([productId, imageId])
}

model CartItem {
  id        String  @id @default(uuid())
  userId    String
  productId String?
  adId      String?
  quantity  Int
  unitPrice Int

  user    User     @relation(fields: [userId], references: [id])
  product Product? @relation(fields: [productId], references: [id])
  ad      Ad?      @relation(fields: [adId], references: [id])

  @@unique([userId, productId])
  @@unique([userId, adId])
}

model Order {
  id String @id @default(uuid())

  userId         String?
  guestSessionId String?

  customerName    String
  customerPhone   String
  customerEmail   String?
  deliveryAddress String
  comment         String?

  status             OrderStatus @default(CREATED)
  totalAmount        Int
  yookassaPaymentId  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  items OrderItem[]

  referralRewards ReferralReward[]
}

model OrderItem {
  id        String @id @default(uuid())
  orderId   String
  productId String
  quantity  Int
  unitPrice Int

  order   Order   @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id])
}

model ReferralLevel {
  id    String @id @default(uuid())
  grade Int
  name  String

  referrals Referral[]

  @@unique([grade])
}

model Referral {
  id            String   @id @default(uuid())
  inviterUserId String
  invitedUserId String   @unique
  levelId       String
  createdAt     DateTime @default(now())

  inviter User @relation("Inviter", fields: [inviterUserId], references: [id])
  invited User @relation("Invited", fields: [invitedUserId], references: [id])

  level   ReferralLevel    @relation(fields: [levelId], references: [id])
  rewards ReferralReward[]
}

model ReferralReward {
  id         String   @id @default(uuid())
  referralId String
  orderId    String
  amount     Int
  createdAt  DateTime @default(now())

  referral Referral @relation(fields: [referralId], references: [id])
  order    Order    @relation(fields: [orderId], references: [id])
}

model CatalogCollection {
  id          String                @id @default(uuid())
  slug        String                @unique
  type        CatalogCollectionType
  title       String
  description String?
  isActive    Boolean               @default(true)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  categories CatalogCollectionCategory[]
  products   CatalogCollectionProduct[]
}

model CatalogCollectionCategory {
  collectionId String
  categoryId   String
  sortOrder    Int    @default(0)

  collection CatalogCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  category   MarketCategory    @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([collectionId, categoryId])
}

model CatalogCollectionProduct {
  collectionId String
  productId    String
  sortOrder    Int    @default(0)

  collection CatalogCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  product    Product           @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([collectionId, productId])
}
