generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  firstName  String
  lastName   String
  patronymic String?
  role       UserRole @default(USER)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  phone      String?
  avatarId   String?
  referralCode String?
}

enum UserRole {
  USER
  REFERRAL_PARTNER
  ADMIN
}